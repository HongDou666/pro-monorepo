{
  "name": "@pro-monorepo/components",
  "version": "1.0.0",
  "description": "组件库 - Vue 3 组件集合",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test": "cd ../.. && vitest run --project components"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "peerDependencies": {
    "vue": "^3.5.0",
    "ant-design-vue": "^4.0.0",
    "@ant-design/icons-vue": "^7.0.0",
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "vue": "^3.5.30",
    "ant-design-vue": "^4.2.6",
    "@ant-design/icons-vue": "^7.0.1",
    "dayjs": "^1.11.20",
    "@pro-monorepo/utils": "workspace:*"
  },
  "buildOptions": {
    "name": "ProMonorepoComponents",
    "formats": [
      "esm",
      "cjs",
      "iife"
    ]
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
